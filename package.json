{
  "name": "ad-automation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "bun run --cwd backend dev",
    "dev:backend": "bun run --cwd backend dev",
    "dev:frontend": "bun run --cwd frontend dev",
    "build:backend": "bun run --cwd backend build",
    "build:frontend": "bun run --cwd frontend build",
    "typecheck:backend": "bun run --cwd backend typecheck",
    "typecheck:frontend": "bun run --cwd frontend typecheck",
    "db:generate": "bun run --cwd backend db:generate",
    "db:migrate": "bun run --cwd backend db:migrate",
    "db:studio": "bun run --cwd backend db:studio",
    "db:up": "docker compose up -d mysql",
    "db:down": "docker compose down",
    "seed:admin": "bun run --cwd backend seed:admin"
  },
  "dependencies": {},
  "devDependencies": {}
}
